{
  "layer": "top",
  "position": "top",
  "height": 28,

  "modules-left": ["sway/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["tray", "sway/language", "custom/volume", "backlight", "battery"],

  "custom/volume": {
    "exec": "pactl get-sink-volume 684 | awk '{print $5}' | tr -d '%\n' && echo '%'",
    "interval": 1,
    "format": " │ VOL {}"
  },

  "backlight": {
    "format": "BR {percent}%"
  },

  "network": {
    "format-wifi": "",
    "format-disconnected": "󰤭"
  },

  "battery": {
    "format": "BAT {capacity}%"
  },

  "clock": {
    "format": "{:%H:%M}"
  },

  "sway/language": {
    "format": "{short}",
    "tooltip": false
  },

  "tray": {
    "icon-size": 16,
    "spacing": 8
  }
}

